# Copy this file to .env.local and fill in real values.
# See: Projects/StockFlow/Environment.md for full documentation.

# ============================================================
# Supabase
# ============================================================

# Project URL (public — bundled into client)
# Format: https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Publishable key — safe for client (replaces legacy "anon" key)
# Find at: Supabase Dashboard → Settings → API Keys → Publishable key
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...

# Secret key — bypasses RLS, server-only, NEVER expose to client
# Find at: Supabase Dashboard → Settings → API Keys → Secret keys (click 👁️ to reveal)
# Replaces legacy "service_role" key
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...

# ============================================================
# Google OAuth
# ============================================================
# Create at: https://console.cloud.google.com/apis/credentials

GOOGLE_OAUTH_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=GOCSPX-your-secret

# ============================================================
# App Config
# ============================================================

# Canonical app URL
# Local:      http://localhost:3000
# Production: https://stockflow.app (or your domain)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional — defaults to "StockFlow"
NEXT_PUBLIC_APP_NAME=StockFlow
