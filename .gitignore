# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# claude code — skills are versioned in .agents/ (portable).
# .claude/skills/ is a Windows-only junction to .agents/skills/ and breaks
# when cloned on macOS/Linux. Re-link with: pnpm dlx skills add shadcn/ui
.claude/skills/

# personal claude code overrides (per-developer, not committed)
.claude/settings.local.json
